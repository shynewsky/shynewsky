# ChatGPT

def solution(queries):
    
    def recur(n, p):
        # 1세대는 항상 Rr
        if n == 1:
            return "Rr"
        
        # 부모 위치
        parent_p = (p - 1) // 4 + 1
        parent_gene = recur(n - 1, parent_p)
        
        # 부모가 순종이면 그대로
        if parent_gene == "RR":
            return "RR"
        if parent_gene == "rr":
            return "rr"
        
        # 부모가 Rr인 경우
        child_order = (p - 1) % 4
        
        if child_order == 0:
            return "RR"
        elif child_order in (1, 2):
            return "Rr"
        else:
            return "rr"
    
    answer = []
    
    for n, p in queries:
        answer.append(recur(n, p))
    
    return answer